---
import "../styles/global.css";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="language" content="fr" />
    <meta name="robots" content="index, follow" />
    <meta
      name="description"
      content="Ô Phil d'Elo - Restaurant Créole au Cap d'Agde. Découvrez une cuisine réunionnaise artisanale, épicée et généreuse. Réservation par téléphone ou SMS."
    />
    <meta name="geo.region" content="FR" />
    <meta name="geo.placename" content="Cap d'Agde" />
    <meta
      property="og:title"
      content="Ô Phil d'Elo - Restaurant Créole au Cap d'Agde"
    />
    <meta
      property="og:description"
      content="Cuisine réunionnaise artisanale, épicée et généreuse. Découvrez nos plats signatures et notre ambiance tropicale."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.ophildelo.com" />
    <meta
      property="og:image"
      content="https://www.ophildelo.com/images/plat-creole.jpg"
    />
    <title>
      Ô Phil d'Elo - Restaurant Créole au Cap d'Agde | Cuisine Réunionnaise
    </title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <script
      src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
      defer></script>
    <script type="module">
      window.axeptioSettings = {
        clientId: "6a2c03b634b43d62e0c8e613",
        cookiesVersion: "eb70a2bd-7ac5-40db-aeb0-b742e6bf2d3e",
        googleConsentMode: {
          default: {
            analytics_storage: "denied",
            ad_storage: "denied",
            ad_user_data: "denied",
            ad_personalization: "denied",
            wait_for_update: 500,
          },
        },
      };
      (function (d, s) {
        var t = d.getElementsByTagName(s)[0],
          e = d.createElement(s);
        e.async = true;
        e.src = "//static.axept.io/sdk.js";
        t.parentNode.insertBefore(e, t);
      })(document, "script");
    </script>
  </head>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-1GZXSNEMF1"
  ></script>
  <script type="module">
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag("js", new Date());
    gtag("config", "G-1GZXSNEMF1");
  </script>
</html>
<body>
  <nav
    class="fixed top-0 w-full z-50 glass-nav border-b border-stone-200/60 transition-all duration-300"
  >
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2 group">
        <div
          class="w-8 h-8 bg-blue rounded-lg flex items-center justify-center text-white rotate-3 group-hover:rotate-6 transition-transform"
        >
          <span class="font-bold text-lg tracking-tighter text-yellow">Ô</span>
        </div>
        <span
          class="text-xl font-semibold tracking-tight text-blue"
          data-i18n="nav.brand">Phil d'Elo - Restaurant Créole</span
        >
      </a>
      <div class="flex items-center gap-2">
        <button
          id="lang-toggle"
          type="button"
          class="flex items-center gap-1 px-3 py-1 rounded-full bg-stone-100 hover:bg-stone-200 border border-stone-200 transition-colors text-sm font-medium"
        >
          <iconify-icon icon="solar:globe-linear" width="16"></iconify-icon>
          <span id="lang-toggle-label">🇫🇷 FR</span>
        </button>
      </div>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <script>
    import { initI18n } from "../scripts/i18n";
    initI18n();
  </script>
</body>
